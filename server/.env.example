# Gonna need these if you plan on running it on like your own machine
ALPACA_API_KEY=api_key_from_alpaca
ALPACA_SECRET_KEY=api_secret_from_alpaca

# Neon Postgres. Scheme must be postgresql+asyncpg:// (Neon's dashboard copies
# plain postgresql://, which won't work with SQLAlchemy's async engine).
# asyncpg doesn't understand libpq's sslmode=require — use ssl=require instead.
#
# DATABASE_URL: the pooled (PgBouncer) connection, used by the app at runtime.
#   Host looks like ep-xxx-pooler.region.aws.neon.tech
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?ssl=require
# DATABASE_URL_DIRECT: the non-pooled connection, used only by Alembic migrations
# (the pooler doesn't reliably support the session-level ops migrations need).
#   Same credentials/dbname, host just drops the -pooler suffix.
DATABASE_URL_DIRECT=postgresql+asyncpg://user:password@ep-xxx.region.aws.neon.tech/dbname?ssl=require
